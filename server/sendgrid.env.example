# Copy to sendgrid.env (gitignored) and source before running the API server:
#   cp server/sendgrid.env.example server/sendgrid.env
#   # edit sendgrid.env with your real key
#   set -a && source server/sendgrid.env && set +a && npm run dev:server

export SENDGRID_API_KEY="SG.your_api_key_here"
export SENDGRID_FROM_EMAIL="do-not-reply@thecivic-lens.netlify.app"

# If saving subscribers.json fails (read-only deploy), use a writable path:
# export SUBSCRIBERS_FILE="/tmp/civiclens-subscribers.json"

# Uncomment if you use an EU-pinned SendGrid subuser:
# export SENDGRID_DATA_RESIDENCY="eu"
